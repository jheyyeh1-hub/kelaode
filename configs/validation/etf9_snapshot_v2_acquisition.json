{
  "schema_version": "snapshot-acquisition-v2.0",
  "provider": "AKShare/Eastmoney",
  "endpoint": "fund_etf_hist_em",
  "frequency": "daily",
  "adjustment": "qfq",
  "requested_start": "2005-01-01",
  "requested_end": "2026-07-17",
  "ordered_universe": ["510300", "510500", "159915", "512100", "512880", "512480", "518880", "513100", "511010"],
  "network": {
    "timeout_seconds": 30,
    "retries": 3,
    "retry_delay_seconds": [1, 2, 4]
