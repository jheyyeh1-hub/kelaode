  "constraints": {
    "fallback_provider": null,
    "alternate_endpoint": false,
    "symbol_substitution": false,
    "mixed_adjustment": false,
    "partial_snapshot": false,
    "complete_attempt_failure": "discard every artifact from the failed attempt"
  },
  "csv": {
    "encoding": "UTF-8",
    "line_ending": "LF",
    "header": ["date", "open", "high", "low", "close", "volume"],
    "date_format": "YYYY-MM-DD",
    "numeric_format": ".8f",
    "serializer_version": "snapshot-csv-v2.0"
  }
}
