{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kelaode immutable daily snapshot manifest",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "entries": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["symbol", "provider", "endpoint", "adjustment", "requested_start", "requested_end", "actual_start", "actual_end", "row_count", "file_format", "relative_path", "sha256", "downloaded_at", "schema_version"],
        "properties": {
          "symbol": {"type": "string", "minLength": 1},
          "provider": {"type": "string", "minLength": 1},
          "endpoint": {"type": "string", "minLength": 1},
          "adjustment": {"type": "string", "minLength": 1},
          "requested_start": {"type": "string", "format": "date"},
          "requested_end": {"type": "string", "format": "date"},
          "actual_start": {"type": "string", "format": "date"},
          "actual_end": {"type": "string", "format": "date"},
          "row_count": {"type": "integer", "minimum": 1},
          "file_format": {"enum": ["csv", "parquet"]},
          "relative_path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "downloaded_at": {"type": "string", "format": "date-time"},
          "schema_version": {"const": "1.0"},
          "status": {"const": "success"},
          "error": {"type": "null"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
